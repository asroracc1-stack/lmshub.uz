datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Organization {
  id            String         @id @default(uuid())
  name          String
  users         User[]
  groups        Group[]
  conversations Conversation[]
}

model Group {
  id             String       @id @default(uuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  teacherId      String?
  teacher        User?        @relation("TeacherGroups", fields: [teacherId], references: [id])
  students       User[]       @relation("StudentGroup")
}

model User {
  id             String        @id @default(uuid())
  fullName       String
  email          String        @unique
  role           String        // "SUPER_ADMIN", "ADMIN", "TEACHER", "STUDENT", "PARENT"
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  
  // Student relation to Group
  groupId        String?
  group          Group?        @relation("StudentGroup", fields: [groupId], references: [id])
  
  // Teacher relation to Groups they teach
  taughtGroups   Group[]       @relation("TeacherGroups")
  
  // Parent-Student relationship
  parentId       String?
  parent         User?         @relation("ParentStudents", fields: [parentId], references: [id])
  children       User[]        @relation("ParentStudents")

  // Chat relations
  sentMessages   Message[]
  participants   ConversationParticipant[]
}

model Conversation {
  id             String                    @id @default(uuid())
  title          String?
  isGroup        Boolean                   @default(false)
  organizationId String?
  organization   Organization?             @relation(fields: [organizationId], references: [id])
  createdAt      DateTime                  @default(now())
  participants   ConversationParticipant[]
  messages       Message[]
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

model Message {
  id             String       @id @default(uuid())
  body           String
  attachmentUrl  String?
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
}
